# ── Python ────────────────────────────────────────────────────────────────────
.venv/
__pycache__/
*.py[cod]
*.egg-info/
*.pyo

# ── Runtime data & secrets (never bake into the image) ───────────────────────
data/
app/static/logos/*.png
.env
.env.local
.env.*.local

# ── Docs & Claude ─────────────────────────────────────────────────────────────
docs/
.claude/
CLAUDE.md

# ── Version control ───────────────────────────────────────────────────────────
.git/
.gitignore

# ── Tests & dev tooling ───────────────────────────────────────────────────────
tests/
pytest.ini
*.cfg

# ── Docker files themselves (no recursive COPY risk) ─────────────────────────
Dockerfile
.dockerignore
docker-compose.yml

# ── GitHub Actions ────────────────────────────────────────────────────────────
.github/

# ── OS ────────────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ── Dev scripts ───────────────────────────────────────────────────────────────
start.sh
