# Copy this file to .env and fill in your values.
# .env is gitignored — it will never be committed.

# ── Host user mapping ─────────────────────────────────────────────────────────
# Run `id` in your terminal to find your UID and GID.
# This ensures files written to the data volume are owned by your host user.
PUID=1000
PGID=1000

# ── Session secret key ────────────────────────────────────────────────────────
# Must be a long random string. Generate one with:
#   python3 -c "import secrets; print(secrets.token_hex(32))"
# If left unset the app auto-generates one and stores it in /data/.secret,
# but sessions will reset every time the container is recreated.
SECRET_KEY=replace-with-a-long-random-string
